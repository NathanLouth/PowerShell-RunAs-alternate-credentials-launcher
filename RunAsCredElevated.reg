Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\*\shell\RunAsCredElevated]
@="Run as Different User (Elevated)"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\*\shell\RunAsCredElevated\command]
@="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { param($File); $Credential = Get-Credential; Start-Process powershell.exe -Credential $Credential -WorkingDirectory 'C:\\' -ArgumentList \\\"-NoProfile Start-Process '$($File)' -Verb RunAs \\\" }\" \\\"%1\\\""
